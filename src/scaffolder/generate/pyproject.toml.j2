[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"

[project]
name = "(( name ))"
version = "0.1.0"
description = ""
requires-python = ">=3.14"
dependencies = [
[% for dep in deps %]
  "(( dep ))",
[% endfor %]
]

[dependency-groups]
dev = [
  "pytest>=8",
  "pytest-cov",
  "pytest-asyncio",
  "httpx",
  "mypy",
  "ruff>=0.4",
  "ipython",
[% for dep in dev_deps %]
  "(( dep ))",
[% endfor %]
]

[tool.setuptools.packages.find]
where = ["src"]

[tool.pytest.ini_options]
testpaths = ["tests"]
asyncio_mode = "auto"
pythonpath = ["src"]

[tool.ruff]
line-length = 88
exclude = ["alembic/", ".venv/"]

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "ANN", "SIM"]

[tool.mypy]
strict = true
[% if template == "fastapi" %]
[[tool.mypy.overrides]]
module = ["jose.*", "passlib.*"]
ignore_missing_imports = true
ignore_errors = true
[% endif %]
[% if "celery" in addons %]
[[tool.mypy.overrides]]
module = ["celery.*"]
ignore_missing_imports = true
ignore_errors = true
[% endif %]
