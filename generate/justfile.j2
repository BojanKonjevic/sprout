# Show all available commands when `just` is run without arguments
default:
    @just --list

test:
    pytest -v
cov:
    pytest --cov=src --cov-report=term-missing
lint:
    ruff check .
fmt:
    ruff format .
check:
    mypy src/
run:
    [% if template == "fastapi" -%]uvicorn (( pkg_name )).main:app --reload
migrate msg="":
    alembic revision --autogenerate -m "{{msg}}"
upgrade: wait-db
    alembic upgrade head
downgrade:
    alembic downgrade -1
wait-db:
    @echo "Waiting for postgres..."
    @until docker compose exec -T db pg_isready -U postgres; do sleep 1; done
    @echo "Postgres is ready."
db-create:
    docker compose up -d db
    just wait-db
    docker compose exec db createdb -U postgres (( name ))
    docker compose exec db createdb -U postgres (( name ))_test
    just upgrade
db-reset:
    docker compose exec db dropdb -U postgres --if-exists (( name ))
    docker compose exec db dropdb -U postgres --if-exists (( name ))_test
    just db-create
[% else -%]
    python -m (( pkg_name ))
[%- endif %]
[% for recipe in extra_just_recipes %]
(( recipe ))
[% endfor %]
